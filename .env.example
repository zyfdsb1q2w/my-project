# 美霖个人助手 - 环境变量配置模板
# 将此文件复制为 .env 并填写真实的API密钥
# 注意：.env 文件不要提交到GitHub！

# DeepSeek API 配置
# 获取地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 应用配置
APP_NAME=美霖个人助手
APP_VERSION=1.0.0
APP_ENV=production

# 服务器配置（本地开发时使用）
# STREAMLIT_SERVER_PORT=8501
# STREAMLIT_SERVER_ADDRESS=0.0.0.0
# STREAMLIT_SERVER_HEADLESS=false

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=app.log

# 缓存配置
CACHE_TYPE=simple
CACHE_DEFAULT_TIMEOUT=300

# 安全配置
# SECRET_KEY=your_secret_key_here
# DEBUG=false

# 数据库配置（如果需要）
# DATABASE_URL=sqlite:///app.db
# DATABASE_ECHO=false

# 邮件配置（如果需要）
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your_email@gmail.com
# SMTP_PASSWORD=your_email_password
# EMAIL_FROM=your_email@gmail.com

# 第三方服务配置
# OPENWEATHER_API_KEY=your_openweather_api_key
# NEWS_API_KEY=your_news_api_key

# 功能开关
ENABLE_LOVE_SAYING=true
ENABLE_GOAL_TRACKING=true
ENABLE_MOOD_TRACKING=true
ENABLE_DIARY=true
ENABLE_AI_CHAT=true

# PWA配置
PWA_NAME=美霖助手
PWA_SHORT_NAME=美霖
PWA_THEME_COLOR=#4A86E8
PWA_BACKGROUND_COLOR=#ffffff

# 使用说明：
# 1. 复制此文件：cp .env.example .env
# 2. 编辑 .env 文件，填写真实的API密钥
# 3. 确保 .env 在 .gitignore 中，不要提交到GitHub
# 4. 在Vercel部署时，需要在控制台设置环境变量